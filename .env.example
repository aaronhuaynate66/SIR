# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Anthropic / AI ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434

# ─── Neo4j AuraDB ─────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://<id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ─── Resend (emails) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=SIR <noreply@tudominio.com>

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://sir-web.vercel.app

# ─── Vercel Cron (seguridad) ──────────────────────────────────────────────────
CRON_SECRET=...

# ─── Upstash Redis (rate limiting — opcional) ─────────────────────────────────
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Mobile (Expo) — en apps/mobile/.env o EAS Secrets ───────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
EXPO_PUBLIC_API_URL=https://sir-web.vercel.app
EXPO_PUBLIC_REVENUECAT_API_KEY=appl_...
